99_n.jpg?stp=dst-jpg_e15_tt6&_nc_ht=scontent-mia3-1.cdninstagram.com&_nc_cat=111&_nc_oc=Q6cZ2gFES01bG9oKE08RfbuwiYwAN0apMdt6fqza625U_ZbjYTp7GNQJYwLITjqUAp1aYYA&_nc_ohc=gIEZyyoBuTMQ7kNvwGRryzS&_nc_gid=H8ER8X9BDHo0cC7d04BqIA&edm=APU89FABAAAA&ccb=7-5&oh=00_AQACCJ9EO8wBav8fiDPTNEJXcBiX7zkph9WJPgrVfGJA7A&oe=6A61B5D3&_nc_sid=bc0c2c", "images": [], "videoUrl": "https://scontent-mia5-1.cdninstagram.com/o1/v/t2/f2/m86/AQOu2P1CLQhXxa0_JP4jZ8gt6ysDSYJiwvAXMRNMgHg1LdnUxmvLcpFXPXz-L4mJjnHTO5nyzHkNSxZMWFZHrhM57e5aC02zc4ydYOE.mp4?_nc_cat=104&_nc_sid=5e9851&_nc_ht=scontent-mia5-1.cdninstagram.com&_nc_ohc=LrHn1Jcu-jQQ7kNvwG1DtjL&efg=eyJ2ZW5jb2RlX3RhZyI6Inhwdl9wcm9ncmVzc2l2ZS5JTlNUQUdSQU0uQ0xJUFMuQzMuNzIwLmRhc2hfYmFzZWxpbmVfMV92MSIsInhwdl9hc3NldF9pZCI6MTkwNTAxNzQzNjg1OTYyMiwiYXNzZXRfYWdlX2RheXMiOjksInZpX3VzZWNhc2VfaWQiOjEwMDk5LCJkdXJhdGlvbl9zIjozMywidXJsZ2VuX3NvdXJjZSI6Ind3dyJ9&ccb=17-1&vs=82295bbe38a9bb07&_nc_-v5zabiBhUCKAJDMywXQEDmZmZmZmYYEmRhc2hfYmFzZWxpbmVfMV92MREAdf4HZeadAQA&_nc_gid=H8ER8X9BDHo0cC7d04BqIA&_nc_ss=7a22e&_nc_zt=28&oh=00_AQDrXm3fJ2rLDxVHH5LoovKzwv6UqB1zqnbKtfhEa-wrOA&oe=6A5DCCFD", "likesCount": 3967, "videoViewCount": null, "timestamp": "2026-07-09T21:05:39.000Z", "childPosts": [], "ownerUsername": "cleanthatup", "ownerId": "4118548898", "productType": "clips", "isCommentsDisabled": false}, {"id": "3936896290176716508", "type": "Sidecar", "shortCode": "DaiqlE9iU7c", "caption": "Do your AirPods look like this? Let me show you the best way to Clean That Up!\n\nI grab a cotton swab first and gently work out the buildup from the mesh,it pulls up easier than you\u2019d expect. \n\nThen I go in with a toothpick around the edges to get out anything stuck (ear wax is sneaky like that). \n\nOne more pass with a clean swab, then I roll up a little Fun Tac and gently press it into the mesh to pull out what the swab and toothpick couldn\u2019t reach.\n\nFor the case, I like to use a cotton swab for the buildup. Pay extra attention to the charging holes so everything keeps working right. \n\nLast step: 70% isopropyl alcohol on a microfiber towel for a wipe down. These things live in your pocket and your bag all day, so they need the disinfect too.\n\nSave this one for your next cleaning day. \u2728", "hashtags": [], "mentions": [], "url": "https://www.instagram.com/p/DaiqlE9iU7c/", "commentsCount": 12, "dimensionsHeight": 1080, "dimensionsWidth": 1080, "displayUrl": "https://scontent-mia3-1.cdninstagram.com/v/t51.82787-15/736074232_18442933195140899_2602647568605162400_n.jpg?stp=dst-jpg_e15_fr_s1080x1080_tt6&_nc_ht=scontent-mia3-1.cdninstagram.com&_nc_cat=111&_nc_oc=Q6cZ2gFES01bG9oKE08RfbuwiYwAN0apMdt6fqza625U_ZbjYTp7GNQJYwLITjqUAp1aYYA&_nc_ohc=SNZ1Ts8RuDoQ7kNvwFWZxd1&_nc_gid=H8ER8X9BDHo0cC7d04BqIA&edm=APU89FABAAAA&ccb=7-5&oh=00_AQDHupQeAzEXe6vUYXcm1lxzmepsrsikfXo7PNuhOXPItA&oe=6A61E3FD&_nc_sid=bc0c2c", "images": ["https://scontent-mia3-1.cdninstagram.com/v/t51.82787-15/736074232_18442933195140899_2602647568605162400_n.jpg?stp=dst-jpg_e15_fr_s1080x1080_tt6&_nc_ht=scontent-mia3-1.cdninstagram.com&_nc_cat=111&_nc_oc=Q6cZ2gFES01bG9oKE08RfbuwiYwAN0apMdt6fqza625U_ZbjYTp7GNQJYwLITjqUAp1aYYA&_nc_ohc=SNZ1Ts8RuDoQ7kNvwFWZxd1&_nc_gid=H8ER8X9BDHo0cC7d04BqIA&edm=APU89FABAAAA&ccb=7-5&oh=00_AQDHupQeAzEXe6vUYXcm1lxzmepsrsikfXo7PNuhOXPItA&oe=6A61E3FD&_nc_sid=bc0c2c", "https://scontent-mia3-1.cdninstagram.com/v/t51.82787-15/736346376_18442933204140899_962178166553751913_n.jpg?stp=dst-jpg_e15_fr_s1080x1080_tt6&_nc_ht=scontent-mia3-1.cdninstagram.com&_nc_cat=111&_nc_oc=Q6cZ2gFES01bG9oKE08RfbuwiYwAN0apMdt6fqza625U_ZbjYTp7GNQJYwLITjqUAp1aYYA&_nc_ohc=lJbCvONeBIUQ7kNvwHGoziI&_nc_gid=H8ER8X9BDHo0cC7d04BqIA&edm=APU89FABAAAA&ccb=7-5&oh=00_AQAa1bnxksvJy8DkVDxUbPu8A58-IW-lePKGhmpo4jsk7Q&oe=6A61E20D&_nc_sid=bc0c2c"], "alt": null, "likesCount": 423, "timestamp": "2026-07-08T18:17:11.000Z", "childPosts": [{"id": "3936894952977269587", "type": "Image", "caption": "", "hashtags": [], "mentions": [], "url": null, "commentsCount": 0, "firstComment": "", "latestComments": []