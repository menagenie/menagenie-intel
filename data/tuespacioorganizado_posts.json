Q7kNvwFk0Sd1&_nc_gid=QM3rVHFa60KCNJufrJoOZw&edm=ADp7STQBAAAA&ccb=7-5&oh=00_AQC9Njph2VjPJ-uEMQKJfeSOs58E1XSLWLrP5i6erQklZA&oe=6A61B2A2&_nc_sid=c6f216", "videoUrl": "https://scontent-ord5-2.cdninstagram.com/o1/v/t2/f2/m86/AQMn0NPCbweWwQRjTAbRoFzhtSX1PmsYpVKGM_MOE6IUGirOLDbqmtzPD0FHA-wfzn24bdqvWqWEQWuDRxrPUrF4pJF76rnOm7SruAU.mp4?_nc_cat=105&_nc_sid=5e9851&_nc_ht=scontent-ord5-2.cdninstagram.com&_nc_ohc=RX74VxZwu1IQ7kNvwFVlIQ6&efg=eyJ2ZW5jb2RlX3RhZyI6Inhwdl9wcm9ncmVzc2l2ZS5JTlNUQUdSQU0uQ0xJUFMuQzMuNzIwLmRhc2hfYmFzZWxpbmVfMV92MSIsInhwdl9hc3NldF9pZCI6MzU4MzM1MTU1ODQ4OTM1OCwiYXNzZXRfYWdlX2RheXMiOjIxLCJ2aV91c2VjYXNlX2lkIjoxMDA5OSwiZHVyYXRpb25fcyI6MTQxLCJ1cmxnZW5fc291cmNlIjoid3d3In0%3D&ccb=17-1&vs=debe06cac2627b5b&_nc_&_nc_gid=Oep0IvZZoFSeNTbv3ZccmA&_nc_ss=72a8c&_nc_zt=28&oh=00_AQBJ5zKDS00uZb7PI5nxDUTY2XKMlFF6CEYmGZ8UJdCVDA&oe=6A5DB88A", "musicInfo": {"artist_name": "tuespacioorganizado", "song_name": "Original audio", "uses_original_audio": true, "should_mute_audio": false, "should_mute_audio_reason": "", "audio_id": "27602910726012957"}, "ownerUsername": "tuespacioorganizado", "ownerFullName": "Brenda Haines\u00ae\ufe0f"}, {"shortCode": "DZ8xTTnREG2", "url": "https://www.instagram.com/p/DZ8xTTnREG2/", "caption": "De una jarra rajada hago una maceta. \ud83d\ude33\n\n\ud83d\udc49 Hoy me dijeron esta frase, y me qued\u00f3 dando vueltas en la cabeza todo el d\u00eda. \n\ud83d\udc49 Es incre\u00edble como unos la tirar\u00edan, otros la regalar\u00edan y otros (con tal de no hacer ninguna de las opciones anteriores), la reinventan.\n\ud83d\udc49 A ver, no est\u00e1 ni bien ni mal, simplemente, es el principio de la acumulaci\u00f3n, y lo digo x experiencia.\n\ud83d\udc49 Estoy a favor del reciclaje en todos sus sentidos, pero la acumulaci\u00f3n es otra cosa.\n\ud83d\udc49 Cuando algo se rompe, a veces, podemos repararlo y otras no. \nQue podamos repararlo, no significa que vaya a quedar como era antes de romperse, eso es imposible. \nSignifica que en el mejor de los casos, podemos seguir us\u00e1ndolo para el mismo fin.\n\ud83d\udc49 Pero si el fin en cuesti\u00f3n se disolvi\u00f3, por qu\u00e9 nos cuesta tanto deshacernos del objeto?\n\ud83d\udc49 Necesitamos una maceta con forma de jarra rajada? No. Suma? No. \nTanto perder\u00edamos si nos despedimos de ella y en otro momento, cuando podamos o lo creamos necesario, volvemos a comprarla?\n\ud83d\udc49 Porque lo que necesitamos, en realidad, es una jarra, no una maceta. Incluso, probablemente, tengamos que pensar en buscar tierra y una planta.\n\ud83d\udc49 Terminamos gastando dinero en el vivero y seguimos llorando a la jarra, convertida en maceta que no queremos, y en realidad, nunca vamos a querer. \n\ud83d\udc49 Vamos a mirarla cada d\u00eda haciendo un esfuerzo y tratando de auto convencernos de que nos encanta nuestra obra de arte, pero no, en el fondo, empezamos a rodearnos de un cementerio de cosas que no nos dan felicidad.\n\ud83d\udc49 La maceta nunca va a devolvernos la jarra y la jarra nunca va a parecerse a una maceta \ud83d\ude0a\n\n#tuespacioorganizado #parati", "timestamp": "2026-06-24T01:06:23.000Z", "videoDuration": 52.378, "videoPlayCount": 158217, "videoViewCount": 66194, "likesCount": 5158, "commentsCount": 146, "displayUrl": "https://scontent-bos5-1.cdninstagram.com/v/t51.82787-15/728951269_18600883417001837_4078214190600185152_n.jpg?stp=dst-jpg_e15_tt6&_nc_ht=scontent-bos5-1.cdninstagram.com&_nc_cat=105&_nc_oc=Q6cZ2gGZgCJaZoQg1m4S2T4QcCmIqCcEmx3csadMStY-ZoyV_rqX43YE_t6G5zS-Z1Vj9fI&_nc_ohc=LJdzK5IoWaUQ7kNvwGYfwiV&_nc_gid=qCY3OAcsSi5M3Qg_4_DGNQ&edm=ADp7STQBAAAA&ccb=7-5&oh=00_AQBuPg3jzvP25WznJBpKOGNWJS0BMwrJtBg3W-9ELJcVUA&oe=6A61A80D&_nc_sid=c6f216", "videoUrl": "https://instagram.flas1-2.fna.fbcdn.net/o1/v/t2/f2/m367/AQO4nvQ7GiCCfKDZzPXbs885PpZ6uyDcuJsq4dhsEKlKd0hlHHNa1pbGCm-Wr1wGX0JoBNOVzUwWhkHns1nsjw26sfZ9I95DotOT1i4.mp4?_nc_cat=101&_nc_oc=AdoUyg98nuGSmtANT-GGUJpX5UqHCFJ-nsg8pJ3ZJP6umZ1UQ2p8lJvtIsYweSgSY2s&_nc_sid=9ca052&_nc_ht=instagram.flas1-2.fna.fbcdn.net&_n