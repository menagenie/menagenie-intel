jb2RlX3RhZyI6InByb2ZpbGVfcGljLmRqYW5nby45MjQuYzIifQ&_nc_ht=instagram.flas1-2.fna.fbcdn.net&_nc_cat=106&_nc_oc=Q6cZ2gGwFhZyi0KKTMsl2HpfVGbvlPlmi5ngb3f3lPqRPIbilvd57weVsOTH1YaeXiJEb1c&_nc_ohc=qAuhy_I9kwIQ7kNvwFO7C9e&_nc_gid=YWVoe6jPpgD7W9ohjO9o-w&edm=AOQ1c0wBAAAA&ccb=7-5&oh=00_AQAmlGT_oLanMvLb0UWFBxHZX-mpm-iSI99Cm7PyRJiPhA&oe=6A61B4C1&_nc_sid=8b3546", "profilePicUrlHD": "https://instagram.flas1-2.fna.fbcdn.net/v/t51.2885-19/405755197_1363486277618034_3820953970557906577_n.jpg?stp=dst-jpg_s320x320_tt6&efg=eyJ2ZW5jb2RlX3RhZyI6InByb2ZpbGVfcGljLmRqYW5nby45MjQuYzIifQ&_nc_ht=instagram.flas1-2.fna.fbcdn.net&_nc_cat=106&_nc_oc=Q6cZ2gGwFhZyi0KKTMsl2HpfVGbvlPlmi5ngb3f3lPqRPIbilvd57weVsOTH1YaeXiJEb1c&_nc_ohc=qAuhy_I9kwIQ7kNvwFO7C9e&_nc_gid=YWVoe6jPpgD7W9ohjO9o-w&edm=AOQ1c0wBAAAA&ccb=7-5&oh=00_AQBqfSx_UNnbH1x_Fn9nUEApbHP3dZ2d_biwmzyFVYcyUA&oe=6A61B4C1&_nc_sid=8b3546", "igtvVideoCount": 0, "relatedProfiles": [], "latestIgtvVideos": [], "postsCount": 65, "latestPosts": [{"id": "3296735894319940638", "type": "Video", "shortCode": "C3AW9Q7OEQe", "caption": "\ud83e\udef5\ud83c\udffd Always charge your worth...\n\n\u2049\ufe0f But first, you must know what your worth is and how to communicate that to your clients...\n\n\ud83e\uddfd In the commercial cleaning industry most locations cannot open up in the morning without having a professional cleaning service at their location...\n\n\ud83d\uded1 That means we are a NECESSITY...\n\n\ud83d\udc40 Of course the client's job is to keep an eye on the budget and try to save money when they can...\n\n\ud83d\udde3\ufe0f Our job as a professional cleaning service is to communicate how we can solve their problems, simultaneously changing their perception of the value we provide...\n\n\ud83d\udccb This approach allows you to deliver your proposal based on your ability to solve their problems not on their budget...\n\n\ud83d\udcb8 Comment \"WORTH\" to learn more about how to raise your prices and get paid your worth!\n\n#cleaningcommunity \n#cleaningbusiness \n#cleaningcoach \n#Cleanpreneurship", "hashtags": ["cleaningcommunity", "cleaningbusiness", "cleaningcoach", "Cleanpreneurship"], "mentions": [], "url": "https://www.instagram.com/p/C3AW9Q7OEQe/", "commentsCount": 1, "dimensionsHeight": 1137, "dimensionsWidth": 640, "displayUrl": "https://instagram.flas1-2.fna.fbcdn.net/v/t51.71878-15/502749449_722330210542147_2441429076413902407_n.jpg?stp=dst-jpg_e15_tt6&_nc_ht=instagram.flas1-2.fna.fbcdn.net&_nc_cat=107&_nc_oc=Q6cZ2gGwFhZyi0KKTMsl2HpfVGbvlPlmi5ngb3f3lPqRPIbilvd57weVsOTH1YaeXiJEb1c&_nc_ohc=-SlT0aihfD4Q7kNvwF_77GD&_nc_gid=YWVoe6jPpgD7W9ohjO9o-w&edm=AOQ1c0wBAAAA&ccb=7-5&oh=00_AQAjIPXIhXNY2syz2mryOhV4w4jQcE9iXN545N1W2wOmtg&oe=6A61B55A&_nc_sid=8b3546", "images": [], "videoUrl": "https://instagram.flas1-1.fna.fbcdn.net/o1/v/t2/f2/m82/AQPhem0Qpz_btMwcLU5kJNEFnVM5T5a4jDFLFjCU6aA1miodovlOs_GSgFj6k4o5Kho7H9QOvHEqU7v6mSssolw3vG79wQroinj7naw.mp4?_nc_cat=106&_nc_oc=Adpc3x53-a8gpi3-HFLAgXNLQflpg_oG5KG5ihJN32S8DGdgfkXYm8m3P3Oe-Wj8sRk&_nc_sid=5e9851&_nc_ht=instagram.flas1-1.fna.fbcdn.net&_nc_ohc=4Rvn22ARW_cQ7kNvwG0ctPN&efg=eyJ2ZW5jb2RlX3RhZyI6Inhwdl9wcm9ncmVzc2l2ZS5JTlNUQUdSQU0uQ0xJUFMuQzMuNzIwLmRhc2hfYmFzZWxpbmVfMV92MSIsInhwdl9hc3NldF9pZCI6Mzc0MjAzNDYyMDIxNDkyLCJhc3NldF9hZ2VfZGF5cyI6ODkzLCJ2aV91c2VjYXNlX2lkIjoxMDA5OSwiZHVyYXRpb25fcyI6OSwidXJsZ2VuX3NvdXJjZSI6Ind3dyJ9&ccb=17-1&vs=8b0a077d502794cb&_nc_-B2XmnQEA&_nc_gid=YWVoe6jPpgD7W9ohjO9o-w&_nc_map=urlgen_bucketless&_nc_zt=28&_nc_ss=7a3ba&oh=00_AQAPf588witVtLDgWOhxWxZBeUYZE4cHRlcPP8WuFcGXfg&oe=6A5DB66B", "alt": null, "likesCount": 28, "videoViewCount": 132, "timestamp": "2024-02-06T12:23:23.000Z", "childPosts": [], "ownerUsername": "cleaning_biz_growth_academy", "ownerId": "53463611699", "productType": "clips", "musicInfo": {"artist_name": "Killer Mike, Andr\u00e9 3000", "song_name": "SCIENTISTS & ENGINEERS (feat. Future, Eryn Allen Kane)", "uses_original_audio": false, "should_mute_audio": false, "should_mute_audio_reason": "", "audio_id": "633346268239034"}, "isComment